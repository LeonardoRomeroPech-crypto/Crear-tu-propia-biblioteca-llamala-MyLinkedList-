class Node:
    def __init__(self, data):
        self.data = data
        self.next = None


class MyLinkedList:
    def __init__(self):
        self.head = None

    # Verificar si está vacía
    def is_empty(self):
        return self.head is None

    # Insertar al inicio
    def insert_beginning(self, data):
        new_node = Node(data)
        new_node.next = self.head
        self.head = new_node

    # Insertar al final
    def insert_end(self, data):
        new_node = Node(data)
        
        if self.head is None:
            self.head = new_node
            return
        
        temp = self.head
        while temp.next:
            temp = temp.next
        
        temp.next = new_node

    # Insertar en posición
    def insert_position(self, data, position):
        if position == 0:
            self.insert_beginning(data)
            return
        
        new_node = Node(data)
        temp = self.head
        
        for _ in range(position - 1):
            if temp is None:
                raise IndexError("Posición fuera de rango")
            temp = temp.next
        
        new_node.next = temp.next
        temp.next = new_node

    # Eliminar por valor
    def delete(self, data):
        temp = self.head

        if temp and temp.data == data:
            self.head = temp.next
            return

        prev = None
        while temp and temp.data != data:
            prev = temp
            temp = temp.next

        if temp is None:
            print("Elemento no encontrado")
            return

        prev.next = temp.next

    # Buscar elemento
    def search(self, data):
        temp = self.head
        position = 0

        while temp:
            if temp.data == data:
                return position
            temp = temp.next
            position += 1

        return -1

    # Obtener tamaño
    def size(self):
        count = 0
        temp = self.head

        while temp:
            count += 1
            temp = temp.next

        return count

    # Mostrar lista
    def display(self):
        temp = self.head
        while temp:
            print(temp.data, end=" -> ")
            temp = temp.next
        print("None")

    # Limpiar lista
    def clear(self):
        self.head = None
